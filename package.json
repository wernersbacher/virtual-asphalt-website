{
  "name": "virtualAsphalt",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run prebuild && vite --port 3000",
    "start": "vite --port 3000",
    "preview": "vite preview",
    "prebuild": "node scripts/build-gallery.ts && node scripts/build-calendar.ts",
    "build:calendar": "node scripts/build-calendar.ts",
    "build:gallery": "node scripts/build-gallery.ts",
    "build": "vite build && tsc",
    "serve": "vite preview",
    "test": "vitest run",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "prettier",
    "check": "prettier --write . && oxlint --fix"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.14",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-navigation-menu": "^1.2.16",
    "@radix-ui/react-slot": "^1.3.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-devtools": "^0.10.8",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "npm-check-updates": "^22.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "cross-env": "^10.1.0",
    "jsdom": "^29.1.1",
    "oxlint": "^1.72.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "web-vitals": "^5.3.0"
  }
}
